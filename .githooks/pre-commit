#!/usr/bin/env bash
# Runs cargo fmt --check on the workspace. Aborts the commit if anything
# would need reformatting. Run `cargo fmt --all` to fix.

set -eu

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo not found in PATH, skipping fmt check"
    exit 0
fi

# Only run when Rust files are staged.
if ! git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.rs$'; then
    exit 0
fi

if ! cargo fmt --all -- --check; then
    echo
    echo "pre-commit: 'cargo fmt --all' would change files. Run it and re-stage."
    exit 1
fi
